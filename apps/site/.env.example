# swarm.impt.io — required env vars (set in CF Pages dashboard, never commit values)
#
# Source for IMPT-shared keys: /home/mike/impt-management/vercel-env-backup/impt-marketplace.env
# Copy into Cloudflare Pages project "swarm-impt" → Settings → Environment Variables.

# ─── Storage (KV namespace IDs go in wrangler.toml) ───
# Run in CF dashboard or via: wrangler kv:namespace create <NAME>
# INTENTS   — intent_id → Intent record (90 day TTL)
# PARTNERS  — partner_key + email → Partner record (5 year TTL)
# ANALYTICS — event_id → tracking event (90 day TTL)

# ─── Stripe (P0.5+ — already wired in PR #2 only as webhook listener; checkout creation P1+) ───
STRIPE_SECRET_KEY=         # sk_live_... from impt-marketplace.env
STRIPE_WEBHOOK_SECRET=     # whsec_... from impt-marketplace.env

# ─── Sendgrid (partner welcome emails) ───
SENDGRID_API_KEY=          # SG.<token> from impt-marketplace.env
SENDGRID_FROM_EMAIL=       # e.g. partners@impt.io (must be verified sender on Sendgrid)
SENDGRID_FROM_NAME=IMPT Swarm

# ─── Alerts ───
ALERT_WEBHOOK=             # internal webhook that emails mike@impt.io (uptime + conversion alerts)

# ─── IMPT internal proxy ───
IMPT_API_BASE=https://platform.impt.io/api
# IMPT_API_TOKEN=          # uncomment if internal API requires auth

# ─── P1 (Telegram + WhatsApp) — defer for PR #4/#5 ───
# TG_BOT_TOKEN=
# WA_PHONE_NUMBER_ID=
# WA_TOKEN=
